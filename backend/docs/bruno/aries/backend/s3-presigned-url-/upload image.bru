meta {
  name: upload image
  type: http
  seq: 3
}

put {
  url: {{protocol}}://{{host}}:{{port}}/api/v1/s3/upload/aries-img-bucket/666
  body: multipartForm
  auth: inherit
}

headers {
  Content-Type: multipart/form-data
}

body:multipart-form {
  file: @file(/home/lulski/Pictures/backgrounds/16.jpg)
}

settings {
  encodeUrl: false
  timeout: 0
}
