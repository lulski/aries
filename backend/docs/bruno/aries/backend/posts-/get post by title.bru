meta {
  name: get post by title
  type: http
  seq: 2
}

get {
  url: {{protocol}}://{{host}}:{{port}}/api/v1/posts?id=6933ea80ace9930533131a30
  body: none
  auth: basic
}

params:query {
  id: 6933ea80ace9930533131a30
  ~title: eleventh-post
}

headers {
  User-Agent: insomnia/10.2.0
  X-CSRF-TOKEN: undefined
}

auth:basic {
  username: {{api_username}}
  password: {{api_password}}
}
