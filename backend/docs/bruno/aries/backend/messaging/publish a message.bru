meta {
  name: publish a message
  type: http
  seq: 1
}

post {
  url: {{protocol}}://{{host}}:{{port}}/api/v1/messages
  body: json
  auth: inherit
}

body:json {
          {
              "exchange": "test-exchange",
              "routingKey": "test-routing-key",
              "message": "Hello 123"
          }
}

settings {
  encodeUrl: true
  timeout: 0
}
